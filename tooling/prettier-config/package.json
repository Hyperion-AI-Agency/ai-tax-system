{
  "name": "@tooling/prettier-config",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./base.js"
  },
  "files": [
    "base.js"
  ],
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "format:fix": "prettier --write . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "catalog:default",
    "prettier": "catalog:default",
    "prettier-plugin-tailwindcss": "catalog:tailwind"
  },
  "prettier": "@tooling/prettier-config"
}
