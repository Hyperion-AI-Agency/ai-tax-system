{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Astro",
  "extends": "./base.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [".astro/types.d.ts", "**/*.tsx", "**/*.ts", "**/*.astro"],
  "exclude": ["node_modules"]
}
