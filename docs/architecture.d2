# AI Tax System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 5
grid-gap: 120

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Transparent slot so the user card stays 160x160 but the grid cell absorbs stretch.
user_slot: "" {
  style.fill: transparent
  style.stroke: transparent

  cpa: CPA User {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
  }
}

app_zone: "App" {
  grid-columns: 2
  grid-gap: 30

  web: Next.js Upload {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
  api: FastAPI {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

extraction_zone: "Extraction Pipeline" {
  grid-columns: 3
  grid-gap: 30

  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  extractor: Extraction Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}

data_zone: "Data" {
  grid-columns: 2
  grid-gap: 30

  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  storage: S3 (KMS) {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

integrations_zone: "3rd Party Integrations" {
  grid-columns: 2
  grid-gap: 30

  claude: Claude API {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  target: ProConnect / DrakeTax {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
  }
}

# Zone-to-zone flow. No per-card arrows. Linear, L-to-R.
user_slot.cpa -> app_zone: "1. Upload"
app_zone -> extraction_zone: "2. Extract fields"
extraction_zone -> data_zone: "3. Persist"
data_zone -> integrations_zone: "4. Export"
