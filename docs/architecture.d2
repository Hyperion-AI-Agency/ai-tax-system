# AI Tax System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 60

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Entry point - outside the system
cpa: CPA User {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}

app_zone: "App" {
  grid-columns: 2
  grid-gap: 30

  web: Next.js Upload {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
  api: FastAPI {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

extraction_zone: "Extraction Pipeline" {
  grid-columns: 3
  grid-gap: 30

  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  claude: Claude Extraction {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}

data_zone: "Data" {
  grid-columns: 2
  grid-gap: 30

  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  storage: S3 (KMS) {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

integrations_zone: "3rd Party Integrations" {
  target: ProConnect / DrakeTax {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
  }
}

cpa -> app_zone.web: "1. Upload return"
app_zone.web -> app_zone.api: "2. POST /returns"
app_zone.api -> extraction_zone.ocr: "3. Enqueue"
extraction_zone.ocr -> extraction_zone.claude: "4. Extract"
extraction_zone.claude -> extraction_zone.review: "5. Low-confidence"
extraction_zone -> app_zone.api: "6. Verified fields"
app_zone.api -> data_zone: "7. Persist"
app_zone.api -> integrations_zone.target: "8. Export"
