# AI Tax System - Architecture (generated from freebie.diagram spec)
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk ... docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
  hidden: {
    style.fill: transparent
    style.stroke: transparent
  }
}

# Layout: [entry] -> [core: Data / App / Integrations stacked] -> [processing] -> [observability?]

entry_slot: "" { class: hidden
  entry: CPA User {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
  }
}

core: "" { class: hidden
  direction: down

  data_zone: "Data" {
    grid-columns: 2
    grid-gap: 80
    db: Postgres {
      class: card
      icon: https://cdn.simpleicons.org/postgresql
    }
    storage: S3 (KMS) {
      class: card
      icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
    }
  }

  app_zone: "App" {
    grid-columns: 2
    grid-gap: 80
    web: Next.js Frontend {
      class: card
      icon: https://cdn.simpleicons.org/nextdotjs
    }
    api: FastAPI Backend {
      class: card
      icon: https://cdn.simpleicons.org/fastapi
    }
  }

  integrations_zone: "3rd Party Integrations" {
    grid-columns: 3
    grid-gap: 80
    claude: Claude API {
      class: card
      icon: https://cdn.simpleicons.org/anthropic
    }
    proconnect: ProConnect {
      class: card
      icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
    }
    draketax: DrakeTax {
      class: card
      icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
    }
  }
}

processing_zone: "Extraction Pipeline" {
  grid-columns: 1
  grid-gap: 80
  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  extractor: Extraction Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}


# --- Arrows (zone-to-zone, max 6, linear) ---
entry_slot.entry -> core.app_zone: "1. Upload"
core.app_zone -> core.data_zone: "2. Store + create job"
core.data_zone -> processing_zone: "3. Dequeue"
processing_zone -> core.data_zone: "4. Persist verified"
core.app_zone -> core.integrations_zone: "5. Export"
