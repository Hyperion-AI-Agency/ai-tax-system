# AI Tax System - Processing Flow
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout dagre

shape: sequence_diagram

cpa: CPA {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}
api: FastAPI {
  icon: https://cdn.simpleicons.org/fastapi
}
storage: S3 + Queue {
  icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
}
ocr: OCR Worker {
  icon: https://cdn.simpleicons.org/celery
}
claude: Claude {
  icon: https://cdn.simpleicons.org/anthropic
}
target: "ProConnect /\nDrakeTax" {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
}

cpa -> api: "1. Upload tax return"
api -> storage: "2. Encrypted store + enqueue"
storage -> ocr: "3. Dequeue"
ocr -> ocr: "4. Textract OCR"
ocr -> claude: "5. Extract fields + confidence"
claude -> storage: "6. Persist verified fields"
storage -> target: "7. Export ready-to-file" {
  style.stroke: "#059669"
  style.bold: true
}
target -> cpa: "8. Import confirmed"
