# Dependencies and build outputs (reinstalled/built inside container)
node_modules/
**/node_modules/
.next/
**/.next/
**/out/
**/dist/
**/.turbo/
**/.astro/
**/storybook-static/
**/.react-email/

# Git and IDE
.git/
.gitignore
.github/
.husky/
.vscode/
.idea/

# Logs
*.log

# Environment files (secrets set at runtime)
.env
.env.*
!.env.example

# Tests and coverage
coverage/
**/coverage/
**/*.spec.*
**/__tests__/
**/__mocks__/
playwright-report/
test-results/

# Python
__pycache__/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Documentation (not needed in app containers)
apps/mkdocs/
*.md
!README.md

# Misc
.DS_Store
*.pem
.sentryclirc
.basehub
.claude/
