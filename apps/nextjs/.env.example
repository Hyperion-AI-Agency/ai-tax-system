# Frontend URL
NEXT_PUBLIC_APP_URL=http://localhost:3002

# i18n (comma-separated locale codes; default locale used when prefix is omitted)
NEXT_PUBLIC_LOCALES=lt,en
NEXT_PUBLIC_DEFAULT_LOCALE=lt

# Neon PostgreSQL
DATABASE_URL=

# Cloudflare R2
R2_UPLOAD_IMAGE_ACCESS_KEY_ID=
R2_UPLOAD_IMAGE_SECRET_ACCESS_KEY=
CLOUDFLARE_ACCOUNT_ID=
R2_UPLOAD_IMAGE_BUCKET_NAME=images

# Auth
BETTER_AUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payments
POLAR_ACCESS_TOKEN=
POLAR_ENVIRONMENT=sandbox  # "sandbox" or "production"
POLAR_SUCCESS_URL=/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=

# Subscriptions
NEXT_PUBLIC_STARTER_TIER=
NEXT_PUBLIC_STARTER_SLUG=

# GPT API Key
OPENAI_API_KEY=

# Sentry (optional -- leave empty to disable)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=