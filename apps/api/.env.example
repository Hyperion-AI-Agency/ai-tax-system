# API environment variables (use API_ prefix)
# Copy to .env and fill in values

# Database (separate Postgres; with docker-compose.local use port 5433)
API_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/api

# Application
API_PROJECT_NAME=API
API_ENVIRONMENT=local
API_SECRET_KEY=

# CORS (comma-separated origins)
API_BACKEND_CORS_ORIGINS=http://localhost:3002,http://localhost:4000

# Server
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000
API_SERVER_LOG_LEVEL=info
API_SWAGGER_HIDE=false

# OAuth / Better Auth (base URL of Next.js app)
API_OAUTH_PROVIDER_URL=http://localhost:3002
API_OAUTH_CLIENT_ID=
API_OAUTH_CLIENT_SECRET=

# OpenAI
API_OPENAI_API_KEY=

# Apify
API_APIFY_API_TOKEN=

# Tavily (web search)
API_TAVILY_API_KEY=

# File uploads (default: ./uploads; in Docker use a mounted volume path)
# API_UPLOAD_DIR=./uploads

# Celery
API_CELERY_BROKER_URL=redis://localhost:6379/0
API_CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional / Observability
# API_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# API_SENTRY_TRACES_SAMPLE_RATE=0.1
# API_SENTRY_PROFILES_SAMPLE_RATE=0.1
